# Supabase pooled connection for Prisma Client at runtime.
# Copy the transaction pooler URL from Supabase and keep port 6543.
# Add ?pgbouncer=true so Prisma works correctly through the pooler.
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_SUPABASE_POOLED_HOST:6543/postgres?pgbouncer=true"

# Supabase direct connection for Prisma CLI commands such as migrations.
# Copy the direct connection URL from Supabase and keep port 5432.
DIRECT_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_SUPABASE_DIRECT_HOST:5432/postgres"

# OpenAI API key used to normalize typed location queries before geocoding.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# Google OAuth client ID used for responder-side calendar import.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
